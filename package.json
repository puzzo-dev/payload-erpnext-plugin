{
  "name": "payload-erpnext-plugin",
  "version": "1.5.0",
  "description": "Payload CMS plugin for ERPNext integration. Multi-doctype form workflows, credential management, proxy endpoints, and async job forwarding.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./components/ERPNextDocTypeSelect": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/components/ERPNextDocTypeSelect/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/components/ERPNextDocTypeSelect/index.js"
      }
    },
    "./components/ERPNextTargetFieldSelect": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/components/ERPNextTargetFieldSelect/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/components/ERPNextTargetFieldSelect/index.js"
      }
    },
    "./components/CompanySelect": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/components/CompanySelect/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/components/CompanySelect/index.js"
      }
    },
    "./components/CmsCollectionSelect": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/components/CmsCollectionSelect/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/components/CmsCollectionSelect/index.js"
      }
    },
    "./components/CmsCollectionFieldSelect": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/components/CmsCollectionFieldSelect/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/components/CmsCollectionFieldSelect/index.js"
      }
    },
    "./components/ERPNextConnectPanel": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/components/ERPNextConnectPanel/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/components/ERPNextConnectPanel/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/components/ERPNextDocTypeSelect/index.tsx src/components/ERPNextTargetFieldSelect/index.tsx src/components/CompanySelect/index.tsx src/components/CmsCollectionSelect/index.tsx src/components/CmsCollectionFieldSelect/index.tsx src/components/ERPNextConnectPanel/index.tsx --format cjs,esm --dts --clean --out-dir dist --external ioredis",
    "dev": "tsup src/index.ts src/components/ERPNextDocTypeSelect/index.tsx src/components/ERPNextTargetFieldSelect/index.tsx src/components/CompanySelect/index.tsx src/components/CmsCollectionSelect/index.tsx src/components/CmsCollectionFieldSelect/index.tsx src/components/ERPNextConnectPanel/index.tsx --format cjs,esm --dts --watch --out-dir dist --external ioredis",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test 'src/**/*.test.ts'",
    "lint": "eslint src",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "payload",
    "payloadcms",
    "erpnext",
    "cms",
    "plugin"
  ],
  "author": "puzzo-dev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/puzzo-dev/payload-erpnext-plugin.git"
  },
  "homepage": "https://github.com/puzzo-dev/payload-erpnext-plugin#readme",
  "bugs": {
    "url": "https://github.com/puzzo-dev/payload-erpnext-plugin/issues"
  },
  "peerDependencies": {
    "@payloadcms/ui": "3.84.1",
    "payload": "^3.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "ioredis": "^5.4.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "next": "16.2.6",
    "payload": "^3.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0"
  }
}
