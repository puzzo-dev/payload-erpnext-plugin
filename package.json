{
  "name": "payload-erpnext-plugin",
  "version": "1.2.2",
  "description": "Payload CMS plugin for ERPNext integration. Multi-doctype form workflows, credential management, proxy endpoints, and async job forwarding.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./components/ERPNextDocTypeSelect": {
      "import": "./src/components/ERPNextDocTypeSelect/index.tsx",
      "require": "./src/components/ERPNextDocTypeSelect/index.tsx",
      "default": "./src/components/ERPNextDocTypeSelect/index.tsx"
    },
    "./components/ERPNextTargetFieldSelect": {
      "import": "./src/components/ERPNextTargetFieldSelect/index.tsx",
      "require": "./src/components/ERPNextTargetFieldSelect/index.tsx",
      "default": "./src/components/ERPNextTargetFieldSelect/index.tsx"
    },
    "./components/CompanySelect": {
      "import": "./src/components/CompanySelect/index.tsx",
      "require": "./src/components/CompanySelect/index.tsx",
      "default": "./src/components/CompanySelect/index.tsx"
    },
    "./components/LeadSourceSelect": {
      "import": "./src/components/LeadSourceSelect/index.tsx",
      "require": "./src/components/LeadSourceSelect/index.tsx",
      "default": "./src/components/LeadSourceSelect/index.tsx"
    },
    "./components/CmsCollectionSelect": {
      "import": "./src/components/CmsCollectionSelect/index.tsx",
      "require": "./src/components/CmsCollectionSelect/index.tsx",
      "default": "./src/components/CmsCollectionSelect/index.tsx"
    },
    "./components/CmsCollectionFieldSelect": {
      "import": "./src/components/CmsCollectionFieldSelect/index.tsx",
      "require": "./src/components/CmsCollectionFieldSelect/index.tsx",
      "default": "./src/components/CmsCollectionFieldSelect/index.tsx"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/components/ERPNextDocTypeSelect/index.tsx src/components/ERPNextTargetFieldSelect/index.tsx src/components/CompanySelect/index.tsx src/components/LeadSourceSelect/index.tsx src/components/CmsCollectionSelect/index.tsx src/components/CmsCollectionFieldSelect/index.tsx --format cjs,esm --dts --clean --out-dir dist",
    "dev": "tsup src/index.ts src/components/ERPNextDocTypeSelect/index.tsx src/components/ERPNextTargetFieldSelect/index.tsx src/components/CompanySelect/index.tsx src/components/LeadSourceSelect/index.tsx src/components/CmsCollectionSelect/index.tsx src/components/CmsCollectionFieldSelect/index.tsx --format cjs,esm --dts --watch --out-dir dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "payload",
    "payloadcms",
    "erpnext",
    "cms",
    "plugin"
  ],
  "author": "IVarse",
  "license": "MIT",
  "peerDependencies": {
    "@payloadcms/ui": "3.84.1",
    "payload": "^3.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "ioredis": "^5.4.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "next": "16.2.6",
    "payload": "^3.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0"
  }
}